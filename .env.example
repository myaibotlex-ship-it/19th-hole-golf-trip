# Site-wide password gate.
# Visitors must enter this password once to access the site (stored in a 30-day cookie).
# Set the same value in Vercel's Environment Variables UI for production.
# If this variable is not set, the auth gate is disabled and a console warning is shown.
SITE_PASSWORD=

# Supabase — get these from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
